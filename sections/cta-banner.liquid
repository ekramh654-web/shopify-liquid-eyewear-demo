<section class="cta-banner">
  <div class="container">
    <h2>{{ section.settings.heading }}</h2>

    <a href="{{ section.settings.button_link }}" class="cta-button">
      {{ section.settings.button_text }}
    </a>
  </div>
</section>

<style>
.cta-banner {
  padding: 80px 20px;
  text-align: center;
  background: black;
  color: white;
}

.cta-banner .cta-button {
  display: inline-block;
  margin-top: 20px;
  background: white;
  color: black;
  padding: 14px 28px;
  text-decoration: none;
}
</style>

{% schema %}
{
  "name": "CTA Banner",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Upgrade Your Style Today"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "Explore Collection"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    }
  ],
  "presets": [
    {
      "name": "CTA Banner"
    }
  ]
}
{% endschema %}
